# researcher-ai-portal environment configuration
# Copy this file to .env and fill in the values for your environment.
# Lines beginning with # are comments.

# -----------------------------------------------------------------------
# Django core (required)
# -----------------------------------------------------------------------

# Generate a strong key for production:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-before-deploying

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list of valid hostnames; use * only for local dev
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# -----------------------------------------------------------------------
# Database (optional — omit to use SQLite fallback at template.db)
# -----------------------------------------------------------------------

# PostgreSQL example:
# DATABASE_URL=postgresql://researcher:password@localhost:5432/researcher_ai

# -----------------------------------------------------------------------
# Globus OAuth (optional — omit for local dev with Django auth fallback)
# -----------------------------------------------------------------------

# GLOBUS_CLIENT_ID=
# GLOBUS_CLIENT_SECRET=
# GLOBUS_ADMIN_GROUP=
# SOCIAL_AUTH_GLOBUS_REDIRECT_URI=https://yourdomain.com/complete/globus/
# SOCIAL_AUTH_REDIRECT_IS_HTTPS=True

# -----------------------------------------------------------------------
# LLM provider API keys (optional — users can supply keys per session)
# -----------------------------------------------------------------------
# These act as server-side fallbacks when the user leaves the API key
# field blank in the submission form.

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# -----------------------------------------------------------------------
# HuggingFace Hub (optional — suppresses unauthenticated-request warnings
# from the sentence-transformers model used by the researcher-ai RAG layer)
# -----------------------------------------------------------------------

# Prevents the "You are sending unauthenticated requests to the HF Hub" warning.
# Set to your HF token instead if you need higher download rate limits.
HF_HUB_DISABLE_IMPLICIT_TOKEN=1

# Silences the tokenizer fork-safety warning in Celery/Gunicorn worker processes.
TOKENIZERS_PARALLELISM=false

# -----------------------------------------------------------------------
# researcher-ai v2 runtime controls (optional)
# -----------------------------------------------------------------------

# Override the default vision/multimodal model used for figure parsing
# RESEARCHER_AI_VISION_MODEL=gpt-4o

# RAG isolation mode: per_job (default) or shared
# RESEARCHER_AI_RAG_MODE=per_job

# Base directory for per-job RAG vector stores
# RESEARCHER_AI_RAG_BASE_DIR=/tmp

# BioWorkflow rollout mode: off, warn (default), on (strict terminal needs_human_review)
# RESEARCHER_AI_BIOWORKFLOW_MODE=warn

# Hard cap for iterative retrieval refinement rounds in method parsing
# RESEARCHER_AI_MAX_RETRIEVAL_REFINEMENT_ROUNDS=2

# -----------------------------------------------------------------------
# FastAPI / CORS (optional — only needed for a separate frontend dev server)
# -----------------------------------------------------------------------

# FASTAPI_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------
# Celery / Redis (optional — omit to use serial in-process parser mode)
# -----------------------------------------------------------------------

# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------
# Production security (applied automatically when DJANGO_DEBUG=False)
# -----------------------------------------------------------------------

# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
